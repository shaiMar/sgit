{
  "name": "sgit",
  "displayName": "SGit",
  "description": "Shows changed files tracked by git, similar to git status",
  "version": "0.1.0",
  "publisher": "sgit",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["SCM Providers"],
  "icon": "resources/sgit-icon.png",
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sgit-container",
          "title": "SGit – Changed Files",
          "icon": "resources/sgit-icon.svg"
        }
      ]
    },
    "views": {
      "sgit-container": [
        {
          "id": "sgitChangedFiles",
          "name": "Changed Files",
          "when": "true"
        }
      ]
    },
    "commands": [
      {
        "command": "sgit.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "sgit.openDiff",
        "title": "Open Diff"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "sgit.refresh",
          "when": "view == sgitChangedFiles",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
